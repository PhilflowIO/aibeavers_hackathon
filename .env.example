# ─── LLM (Qwen, OpenAI-kompatible API) ──────────────────────────
QWEN_API_KEY=
# OpenAI-kompatibler Endpoint (Sponsor/DashScope). Default = DashScope International.
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# z.B. qwen-max, qwen-plus, qwen-turbo
QWEN_MODEL=qwen-max

# ─── SMTP (Mail senden) ─────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false            # true für Port 465 (implicit TLS)
SMTP_USER=
SMTP_PASSWORD=
# Absender, der in der Mail steht (z.B. "Berater Agent <agent@kanzlei.de>")
SMTP_FROM=

# ─── IMAP (Mail empfangen) ──────────────────────────────────────
IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true            # true für implicit TLS (Port 993)
IMAP_USER=
IMAP_PASSWORD=

# ─── CalDAV (Kalender lesen/erstellen via tsdav) ────────────────
# Beispiele:
#   Nextcloud:  https://cloud.example.de/remote.php/dav
#   Google:     https://apidata.googleusercontent.com/caldav/v2/  (App-Passwort)
#   Fastmail:   https://caldav.fastmail.com/dav/
CALDAV_SERVER_URL=
CALDAV_USER=
CALDAV_PASSWORD=
# Optional: Name des Ziel-Kalenders. Leer = erster gefundener Kalender.
CALDAV_CALENDAR_NAME=

# ─── Demo web app (apps/web) ─────────────────────────────────────
USE_MOCK_ANALYSIS=true       # false = live Qwen analyse/qa
ALLOW_LIVE_ACTION_EXECUTION=false  # true = execute real CRM/calendar/mail side effects
LIVE_ACTION_EXECUTION_SECRET=      # server-only; send as x-demo-execution-secret for live writes
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=         # optional; ElevenLabs default if empty

# CRM (Codex — sandbox)
CRM_PROVIDER=mock          # mock | hubspot | pipedrive
HUBSPOT_ACCESS_TOKEN=
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_COMPANY_DOMAIN=  # e.g. yourcompany

# ─── Pipedrive CRM ──────────────────────────────────────────────
# API-Token unter: https://app.pipedrive.com/settings/api
Pipedrive_API_Key=

# ─── Fördermittel-MCP (optional) ────────────────────────────────
# Pfad zum Fördermittel/-Projekt, in dem `uv run foerder-mcp` läuft. Default =
# <repo>/Fördermittel (funktioniert nach `git clone`). Nur setzen, wenn das Projekt
# woanders liegt. Braucht zur Laufzeit: `uv`, einen ingestierten Qdrant-Index und
# DEEPINFRA_TOKEN (in Fördermittel/.env). Fehlt etwas davon, läuft der Agent ohne
# die Förder-Tools weiter (kein Absturz).
FOERDER_PROJECT_DIR=
