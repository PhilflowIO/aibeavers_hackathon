# Copy to ../.env (repo root of Fördermittel/) or pass via docker compose --env-file.
# DeepInfra token for remote embeddings (OpenAI-compatible). REQUIRED for ingest.
DEEPINFRA_TOKEN=

# Qdrant service URL inside the compose network. Unset -> embedded local mode.
FOERDER_QDRANT_URL=http://qdrant:6333

# Optional overrides (defaults shown).
# FOERDER_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
# FOERDER_COLLECTION_NAME=foerderprogramme
# FOERDER_SEMANTIC_WEIGHT=0.7
# FOERDER_MCP_PORT=8000
