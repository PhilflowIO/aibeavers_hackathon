# Copy to ../.env (repo root of Fördermittel/) or pass via docker compose --env-file.
# DeepInfra token for remote embeddings (OpenAI-compatible). REQUIRED for the
# default (deepinfra) provider — the gold-set-calibrated config.
DEEPINFRA_TOKEN=

# --- Sovereign local fallback (no token, no data leaves the box) -------------
# Switch the embedder to a local Ollama model. bge-m3 is multilingual + 1024-dim
# (== DENSE_DIM), so the Qdrant schema is unchanged. Re-run eval after re-ingest
# to recalibrate (bge-m3 != Qwen3-Embedding-0.6B). Needs: ollama pull bge-m3.
# FOERDER_EMBEDDING_PROVIDER=ollama
# In Docker, localhost is the app container. host.docker.internal points at the
# host Ollama daemon; docker-compose.yml maps it on Linux via host-gateway.
# FOERDER_OLLAMA_EMBEDDING_ENDPOINT=http://host.docker.internal:11434/v1/embeddings
# FOERDER_OLLAMA_EMBEDDING_MODEL=bge-m3

# Qdrant service URL inside the compose network. Unset -> embedded local mode.
FOERDER_QDRANT_URL=http://qdrant:6333

# Optional overrides (defaults shown).
# FOERDER_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
# FOERDER_COLLECTION_NAME=foerderprogramme
# FOERDER_SEMANTIC_WEIGHT=0.7
# FOERDER_MCP_PORT=8000
