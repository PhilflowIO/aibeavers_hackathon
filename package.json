{
  "name": "aibeavers_hackathon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Nacharbeits-Agent für Finanzberater — LangChain-Agent mit Mail (SMTP/IMAP) und Kalender (CalDAV).",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "agent": "tsx src/index.ts",
    "ui": "tsx src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "typecheck:web": "pnpm --filter web exec tsc --noEmit",
    "deploy:web": "bash scripts/deploy-web.sh",
    "sync:web-env": "bash scripts/sync-web-env.sh",
    "enable:live-hero": "bash scripts/sync-web-env.sh"
  },
  "license": "MIT",
  "dependencies": {
    "@arizeai/openinference-instrumentation-langchain": "^4.0.12",
    "@iamsamuelfraga/mcp-pipedrive": "^2.1.0",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.6",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.4.7",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "dotenv": "^17.4.2",
    "ical.js": "^2.2.1",
    "ics": "^3.12.0",
    "imapflow": "^1.3.6",
    "langchain": "^1.4.4",
    "mailparser": "^3.9.9",
    "nodemailer": "^8.0.10",
    "tsdav": "^2.2.2",
    "vcf": "^2.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^25.9.2",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
